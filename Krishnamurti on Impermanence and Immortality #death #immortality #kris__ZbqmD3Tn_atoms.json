[{"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 0.11, "end": 3.84, "text": "Look what we have done, sir.", "duration": 3.73}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 3.84, "end": 8.64, "text": "The ancient Egyptians made their life immortal", "duration": 4.8}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 8.64, "end": 13.87, "text": "and their lovers come and tell it all to pieces.", "duration": 5.23}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 13.87, "end": 17.63, "text": "To the calmness, means merely a mask now.", "duration": 3.76}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 17.63, "end": 20.38, "text": "Goldam mask with a mummy.", "duration": 2.75}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 20.38, "end": 26.18, "text": "I know, so, so, man has sought immortality", "duration": 5.8}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 26.18, "end": 32.04, "text": "through work, through every way to find that,", "duration": 5.86}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 32.04, "end": 34.15, "text": "which is immortal.", "duration": 2.11}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 34.15, "end": 37.52, "text": "What is immortality?", "duration": 3.37}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 37.52, "end": 41.98, "text": "Not the book, not the painting which I have done,", "duration": 4.46}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 41.98, "end": 47.99, "text": "not going to the moon and putting some idiotic flag up there.", "duration": 6.01}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 47.99, "end": 51.45, "text": "Not living a righteous life.", "duration": 3.46}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 51.45, "end": 54.24, "text": "So, what is immortal?", "duration": 2.79}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 54.24, "end": 58.33, "text": "Cetro's, some beautiful, marvellous,", "duration": 4.09}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 58.33, "end": 62.3, "text": "instruments, earth, where comes God.", "duration": 3.97}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 62.3, "end": 66.1, "text": "You build, you carve out of marble,", "duration": 3.8}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 66.1, "end": 69.56, "text": "a marvellous thing of Michelangelo,", "duration": 3.46}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 69.56, "end": 71.76, "text": "earthquake, fire, destroyed.", "duration": 2.2}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 71.76, "end": 74.96, "text": "Some lunatic comes home with a hammer and breaks it up.", "duration": 3.2}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 74.96, "end": 77.29, "text": "It is in none of those.", "duration": 2.33}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 77.29, "end": 81.2, "text": "Every statue becomes a dead thing,", "duration": 3.91}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 81.2, "end": 84.4, "text": "every poem, every painting.", "duration": 3.2}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 84.4, "end": 87.6, "text": "So, what, then one asks, what is immortality?", "duration": 3.2}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 87.6, "end": 90.63, "text": "It's not in the building, just see it,", "duration": 3.03}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 90.63, "end": 92.63, "text": "it's not in the cathedral,", "duration": 2.0}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 92.63, "end": 96.99, "text": "it's not in the saviour, which you have invented,", "duration": 4.36}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 96.99, "end": 100.21, "text": "which thought has invented,", "duration": 3.22}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 100.21, "end": 105.73, "text": "not in the gods that man has created out of his own image,", "duration": 5.52}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 105.73, "end": 109.5, "text": "then what is immortality?", "duration": 3.77}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 109.5, "end": 116.41, "text": "Because that is related to consciousness and today,", "duration": 6.91}, {"source": "Krishnamurti on Impermanence and Immortality #death #immortality #kris__ZbqmD3Tn", "speaker": "Ram Dass", "start": 116.41, "end": 120.41, "text": "unless I find that out, death is a terror.", "duration": 4.0}]