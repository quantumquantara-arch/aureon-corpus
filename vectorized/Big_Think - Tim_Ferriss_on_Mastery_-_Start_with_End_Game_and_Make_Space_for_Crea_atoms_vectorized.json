","pace","reciprocity","kappa","tau"]},{"text":"And you'll be able to beat your friends for a while.","uid":"df6dc7ae192a43af","source":"Big_Think - Tim_Ferriss_on_Mastery_-_Start_with_End_Game_and_Make_Space_for_Crea","start":199.51,"end":202.51,"vector":[0.0,0.2,0.08000000000000002,0.09727272727272726,0.3933333333333333,0.0875,0.0375,0.20500000000000002,0.11668181818181816,0.355,0.5,0.0,0.06,0.1,0.15,0.0,0.0625,0.2,0.0,0.5,0.7616666666666666,0.5443654850794793,0.9065000000000001,0.37650000000000006],"dim_names":["valence","arousal","dominance","topic_depth","rapport","formality","vulnerability","playfulness","intellectual","momentum","certainty","curiosity","warmth","surprise","tension","narrative","metaphor","agency","temporal_focus","scope","pace","reciprocity","kappa","tau"]},{"text":"And maybe even be considered a pretty decent chess player.","uid":"f37fe22194502a09","source":"Big_Think - Tim_Ferriss_on_Mastery_-_Start_with_End_Game_and_Make_Space_for_Crea","start":202.51,"end":205.51,"vector":[0.0,0.019093193253341828,0.0,0.21250000000000002,0.06,0.03181989494000638,0.0375,0.22727204202399748,0.15125,0.25763727730133673,0.1310625095293,0.0,0.06,0.1,0.15,0.0,0.0625,0.2,0.0,0.5,0.7033333333333334,0.1,0.8865000000000001,0.273503685096261],"dim_names":["valence","arousal","dominance","topic_depth","rapport","formality","vulnerability","playfulness","intellectual","momentum","certainty","curiosity","warmth","surprise","tension","narrative","metaphor","agency","temporal_focus","scope","pace","reciprocity","kappa","tau"]},{"text":"But on a deep level, you don't understand the game.","uid":"7ca280a960809957","source":"Big_Think - Tim_Ferriss_on_Mastery_-_Start_with_End_Game_and_Make_Space_for_Crea","start":205.51,"end":207.51,"vector":[0.0,0.2,0.08000000000000002,0.14500000000000002,0.35678279453887,0.10750000000000001,0.0375,0.40776845665459505,0.131,0.38,0.5,0.210768456654595,0.2107556722888818,0.1,0.31583123951777003,0.0,0.0625,0.2,0.0,0.5,0.82,0.39678279453887,0.